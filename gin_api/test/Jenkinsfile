pipeline {
    agent none
    stages {
        stage('Build') {
            agent {
                docker {
                    image 'golang:1.22-alpine'
                    args '-u root:root -e GOCACHE=/tmp/.cache'
                }
            }
            steps {
                // 1. Pull the API code directly into the Go container
                git url: 'https://github.com/Pailin-h3/jenkins.git', branch: 'develop'
                
                // 2. Prep and Build
                sh 'apk add --no-cache git' 
                sh 'go mod download'
                sh 'go build -buildvcs=false -o api-binary .'
            }
        }
        
        stage('Deploy') {
            agent any
            steps {
                script {
                    // 1. Clean up old containers
                    sh 'docker rm -f gin-api-test || true'
                    
                    // 2. IMPORTANT: Move the CORRECT Dockerfile from your API repo 
                    // to the root, or just use the one that is there if you updated it.
                    // Based on your logs, the one in root is likely the "Jenkins" one.
                    
                    sh 'cp gin_api/Dockerfile ./Dockerfile || echo "Using existing root Dockerfile"'
                    
                    // 3. Build using the local Dockerfile
                    sh 'docker build --no-cache -t gin-api-test:latest .'
                    
                    // 4. Run
                    sh 'docker run -d --name gin-api-test -p 3000:8080 gin-api-test:latest'
                    
                    echo "API is live at http://localhost:3000"
                }
            }
        }
    }
}