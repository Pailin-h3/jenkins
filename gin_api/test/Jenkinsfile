pipeline {
    agent none
    stages {
        stage('Build') {
            agent {
                docker {
                    image 'golang:1.22-alpine'
                    args '-u root:root -e GOCACHE=/tmp/.cache'
                }
            }
            steps {
                // 1. Pull the API code directly into the Go container
                git url: 'https://github.com/Pailin-h3/jenkins.git', branch: 'develop'
                
                // 2. Prep and Build
                sh 'apk add --no-cache git' 
                sh 'go mod download'
                sh 'go build -buildvcs=false -o api-binary .'
            }
        }
        
        stage('Deploy') {
            agent any
            steps {
                script {
                    // 1. Kill the old container
                    sh 'docker rm -f gin-api-test || true'
                    
                    // 2. DELETE the wrong Dockerfile that Jenkins keeps checking out
                    sh 'rm -f Dockerfile'
                    
                    // 3. Create the CORRECT Dockerfile from scratch right here
                    // This guarantees no Jenkins-image confusion!
                    writeFile file: 'Dockerfile', text: """
                        FROM alpine:latest
                        RUN apk --no-cache add ca-certificates
                        WORKDIR /root/
                        COPY api-binary .
                        RUN chmod +x api-binary
                        CMD ["./api-binary"]
                    """
                    
                    // 4. Build (it will now use the tiny Alpine file we just wrote)
                    sh 'docker build --no-cache -t gin-api-test:latest .'
                    
                    // 5. Run
                    sh 'docker run -d --name gin-api-test -p 3000:8080 gin-api-test:latest'
                    
                    echo "API is live at http://localhost:3000"
                }
            }
        }
    }
}