pipeline {
    agent none
    stages {
        stage('Build') {
            agent {
                docker {
                    image 'golang:1.22-alpine'
                    args '-u root:root -e GOCACHE=/tmp/.cache'
                }
            }
            steps {
                script {
                    sh 'apk add --no-cache git'
                    
                    // 1. Tell Git to trust this workspace folder
                    sh 'git config --global --add safe.directory /var/jenkins_home/workspace/gin-api/gin-api-test'
                    
                    // 2. Now perform the fast fetch
                    sh 'git fetch --depth=1 origin develop'
                    sh 'git checkout FETCH_HEAD'
                    
                    // 3. Debug check: See if your 0.0.0.0 code is actually here
                    sh 'grep "router.Run" main.go || grep "router.Run" gin_api/main.go || echo "main.go not found"'
                    
                    // 4. Build
                    sh 'go mod download'
                    sh 'go build -buildvcs=false -o api-binary .'
                }
            }
        }
        
        stage('Deploy') {
            agent any
            steps {
                script {
                    sh 'docker rm -f gin-api-test || true'
                    sh 'rm -f Dockerfile'
                    
                    writeFile file: 'Dockerfile', text: """
                        FROM alpine:latest
                        RUN apk --no-cache add ca-certificates
                        WORKDIR /root/
                        COPY api-binary .
                        RUN chmod +x api-binary
                        # Force Gin to release mode to skip the 'localhost' debug message
                        ENV GIN_MODE=release
                        CMD ["./api-binary"]
                    """
                    
                    sh 'docker build --no-cache -t gin-api-test:latest .'
                    sh 'docker run -d --name gin-api-test -p 3000:8080 gin-api-test:latest'
                    
                    echo "API is live at http://localhost:3000"
                }
            }
        }
    }
}