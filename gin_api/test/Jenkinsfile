pipeline {
    agent none
    stages {
        stage('Build') {
            agent {
                docker {
                    image 'golang:1.22-alpine'
                    args '-u root:root -e GOCACHE=/tmp/.cache'
                }
            }
            steps {
                dir('api-workspace') {
                    checkout([$class: 'GitSCM', 
                        branches: [[name: 'develop']], 
                        userRemoteConfigs: [[
                            url: 'https://github.com/Pailin-h3/jenkins.git',
                            credentialsId: 'pailin_git',
                            refspec: '+refs/heads/develop:refs/remotes/origin/develop'
                        ]]
                    ])
                }

                sh '''
                    cd api-workspace
                    apk add --no-cache git
                    go mod download
                    go build -buildvcs=false -o ../api-binary .
                '''
            }
        }

        stage('Deploy') {
            agent any
            steps {
                // Step 3: Deploy
                script {
                    sh 'docker rm -f gin-api-test || true'
                    
                    writeFile file: 'Dockerfile', text: """
                        FROM alpine:latest
                        RUN apk --no-cache add ca-certificates
                        WORKDIR /root/
                        COPY api-binary .
                        RUN chmod +x api-binary
                        CMD ["./api-binary"]
                    """
                    
                    sh 'docker build --no-cache -t gin-api-test:latest .'
                    sh 'docker run -d --name gin-api-test -p 3000:8080 gin-api-test:latest'
                }
            }
        }
    }
}