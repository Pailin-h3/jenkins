pipeline {
    agent none
    stages {
        stage('Build') {
            agent {
                docker {
                    image 'golang:1.22-alpine'
                    args '-u root:root -e GOCACHE=/tmp/.cache'
                }
            }
            steps {
                dir('api-repo') {
                    // Updated git syntax for better branch tracking
                    checkout([$class: 'GitSCM', 
                        branches: [[name: '*/develop']], 
                        userRemoteConfigs: [[url: 'https://github.com/Pailin-h3/jenkins.git']]
                    ])
                    
                    sh 'apk add --no-cache git' 
                    sh 'go mod download'
                    // Build and move the binary up so the Deploy stage can find it
                    sh 'go build -buildvcs=false -o ../api-binary .'
                }
            }
        }
        
        stage('Deploy') {
            agent any
            steps {
                script {
                    sh 'docker rm -f gin-api-test || true'
                    sh 'rm -f Dockerfile'
                    
                    writeFile file: 'Dockerfile', text: """
                        FROM alpine:latest
                        RUN apk --no-cache add ca-certificates
                        WORKDIR /root/
                        COPY api-binary .
                        RUN chmod +x api-binary
                        # Force Gin to release mode to skip the 'localhost' debug message
                        ENV GIN_MODE=release
                        CMD ["./api-binary"]
                    """
                    
                    sh 'docker build --no-cache -t gin-api-test:latest .'
                    sh 'docker run -d --name gin-api-test -p 3000:8080 gin-api-test:latest'
                    
                    echo "API is live at http://localhost:3000"
                }
            }
        }
    }
}